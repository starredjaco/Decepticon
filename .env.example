# =============================================================================
# Decepticon — Environment Variables
# =============================================================================
# The installer copies this file to ~/.decepticon/.env
# Edit with: decepticon config

# --- LLM API Keys (required: at least one) ---
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
# GOOGLE_API_KEY=your-google-key-here

# --- LiteLLM Proxy ---
LITELLM_MASTER_KEY=sk-decepticon-master
LITELLM_SALT_KEY=sk-decepticon-salt-change-me

# --- PostgreSQL ---
POSTGRES_PASSWORD=decepticon

# --- Model Profile ---
# default = Balanced (Opus/Sonnet/Haiku mix, recommended)
# high    = Maximum performance (Opus everywhere, expensive)
# test    = Cheapest (Haiku-only, for development)
DECEPTICON_MODEL_PROFILE=default

# --- LangSmith Tracing (optional) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key-here
# LANGCHAIN_PROJECT=decepticon

# --- Ports (optional) ---
# LANGGRAPH_PORT=2024
# LITELLM_PORT=4000
# POSTGRES_PORT=5432

# --- Advanced (optional) ---
# DECEPTICON_DEBUG=true
